REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=
CORS_ORIGIN="http://localhost:5173,http://localhost:3000"
GENERAL_RATE_LIMIT_MAX=1000
AUTH_RATE_LIMIT_MAX=20
SENSITIVE_ACTION_RATE_LIMIT_MAX=10
LOG_LEVEL=info
LOG_API_REQUESTS=false
SENTRY_DSN=
# Organization timezone for server-side business schedules. Use an IANA timezone.
# UTC timestamps remain the source of truth; browsers display timestamps locally.
APP_TIMEZONE=UTC

# Supabase Free Tier safe defaults
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?schema=public&connection_limit=5&pool_timeout=30"
# Preferred for pg_dump and pg_restore. Use a direct or session-pooler URL.
# Leave blank to fall back to DATABASE_URL.
DATABASE_ADMIN_URL=
# Cloudflare R2 offsite backup credentials. Create an R2 API token with
# Object Read & Write access for the payroll-db-backups bucket.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=payroll-db-backups
R2_REGION=auto
# Optional override. Default: https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT_URL=
# ISO weekday: 1=Monday, 7=Sunday. Monthly snapshot defaults to day 01.
R2_WEEKLY_BACKUP_DAY=7
R2_MONTHLY_BACKUP_DAY=01
R2_AUTO_BACKUP_ENABLED=false
R2_BACKUP_CRON="0 2 * * *"
# Optional. Falls back to APP_TIMEZONE.
R2_BACKUP_CRON_TIMEZONE=
# When true, worker startup creates today's daily backup if it is missing.
R2_BACKUP_RUN_ON_STARTUP=true
# Remote deletion stays disabled until retention is reviewed in production.
R2_REMOTE_DELETE_ENABLED=false
R2_DAILY_RETENTION_DAYS=15
R2_WEEKLY_RETENTION_WEEKS=4
R2_MONTHLY_RETENTION_MONTHS=2
R2_API_TIMEOUT_MS=30000
# Optional: connect the SUPER_ADMIN restart API to your production process manager.
# Example PM2: pm2 restart payroll-api payroll-worker && pm2 restart payroll-frontend
# Do not set this to npm run dev commands inside an already-running dev stack.
APP_RESTART_COMMAND=
APP_RESTART_TIMEOUT_MS=120000
# Optional read replica. Leave blank locally/Supabase Free to fall back to DATABASE_URL.
READ_DATABASE_URL=
DATABASE_POOL_MAX=2
READ_DATABASE_POOL_MAX=1
DATABASE_POOL_CONNECTION_TIMEOUT_MS=30000
DATABASE_POOL_IDLE_TIMEOUT_MS=30000
WORKER_HEARTBEAT_ENABLED=true
WORKER_HEARTBEAT_INTERVAL_MS=30000
PRISMA_TRANSACTION_MAX_WAIT_MS=30000
PRISMA_TRANSACTION_TIMEOUT_MS=60000
SCHEDULER_BATCH_SIZE=50
SCHEDULER_MAX_RESULT_ITEMS=500
SCHEDULER_STALE_RUN_MINUTES=60
# Financial payroll generation concurrency within a scheduler batch. Keep at 1 on small DB plans.
SCHEDULER_EMPLOYEE_CONCURRENCY=1
# Set true for local review/testing. Keep false at high volume; failures remain stored.
SCHEDULER_STORE_ITEM_DETAILS=true
# Automatic runs are enqueued at 11:59 PM: WEEKLY on Saturday, MONTHLY on month end.
# Startup and daily catch-up also enqueue the latest completed cycle when pending.
# Optional. Falls back to APP_TIMEZONE.
PAYROLL_CRON_TIMEZONE=
PAYROLL_CRON_RUN_ON_STARTUP=true
PAYROLL_CRON_CATCH_UP_EXPRESSION="5 0 * * *"
PAYROLL_WORKER_CONCURRENCY=1
PAYROLL_WORKER_RATE_LIMIT_MAX=1
PAYROLL_WORKER_RATE_LIMIT_DURATION=1000
PAYSLIP_WORKER_CONCURRENCY=1
PAYSLIP_WORKER_RATE_LIMIT_MAX=2
PAYSLIP_WORKER_RATE_LIMIT_DURATION=1000
PAYSLIP_SYNC_GENERATION=false
REPORT_MAX_RANGE_DAYS=31
REPORT_TIMEOUT_MS=10000
AUDIT_LOG_RETENTION_DAYS=90
SCHEDULER_ITEM_RETENTION_DAYS=30
EXPORT_FILE_RETENTION_DAYS=3
FAILED_JOB_RETENTION_DAYS=15
ENABLE_PRISMA_QUERY_LOG=false
SLOW_QUERY_MS=1000
SLOW_API_MS=2000
ENABLE_PERFORMANCE_LOG=false
ENABLE_REDIS_CACHE=true
CACHE_DEFAULT_TTL_SECONDS=300
REDIS_CACHE_TIMEOUT_MS=100
SESSION_REDIS_TIMEOUT_MS=500
RESPONSE_SIZE_WARN_BYTES=500000
BCRYPT_ROUNDS=10
JWT_SECRET="replace_with_a_long_random_secret_minimum_64_chars"
JWT_EXPIRES_IN="7d"
AUTH_COOKIE_NAME="payroll_session"
AUTH_IDLE_TIMEOUT_SECONDS=900
SHADOW_DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5433/payroll_shadow"

# Stronger DB / production options for later:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?schema=public&connection_limit=20&pool_timeout=30"
# READ_DATABASE_URL="postgresql://USER:PASSWORD@READ_REPLICA_HOST:5432/postgres?schema=public&connection_limit=20&pool_timeout=30"
# SCHEDULER_BATCH_SIZE=500
# SCHEDULER_MAX_RESULT_ITEMS=1000
# SCHEDULER_EMPLOYEE_CONCURRENCY=10
# SCHEDULER_STORE_ITEM_DETAILS=false
# PAYROLL_WORKER_CONCURRENCY=5
# PAYROLL_WORKER_RATE_LIMIT_MAX=5
# PAYROLL_WORKER_RATE_LIMIT_DURATION=1000
# PAYSLIP_WORKER_CONCURRENCY=5
# PAYSLIP_WORKER_RATE_LIMIT_MAX=10
# PAYSLIP_WORKER_RATE_LIMIT_DURATION=1000
# PAYSLIP_SYNC_GENERATION=false
# REPORT_MAX_RANGE_DAYS=366
# REPORT_TIMEOUT_MS=30000
# AUDIT_LOG_RETENTION_DAYS=365
# SCHEDULER_ITEM_RETENTION_DAYS=90
# EXPORT_FILE_RETENTION_DAYS=7
# FAILED_JOB_RETENTION_DAYS=30
# ENABLE_REDIS_CACHE=true
# CACHE_DEFAULT_TTL_SECONDS=300
# RESPONSE_SIZE_WARN_BYTES=500000
# BCRYPT_ROUNDS=12
# CORS_ORIGIN="https://your-frontend-domain.com,https://admin.your-domain.com"
# LOG_LEVEL=info
# LOG_API_REQUESTS=false
# SENTRY_DSN="your_sentry_dsn"
